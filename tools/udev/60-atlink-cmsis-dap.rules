# ARTERY AT-Link / CMSIS-DAP debug probe access for Linux.
# Keep the Artery vendor rule first; the generic rules cover common CMSIS-DAP
# firmware variants used by compatible probes.
SUBSYSTEM=="usb", ATTR{idVendor}=="2e3c", MODE="0666", GROUP="plugdev", TAG+="uaccess"
SUBSYSTEM=="usb", ATTR{idVendor}=="0d28", MODE="0666", GROUP="plugdev", TAG+="uaccess"
SUBSYSTEM=="usb", ATTR{idVendor}=="c251", MODE="0666", GROUP="plugdev", TAG+="uaccess"
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="2e3c", MODE="0666", GROUP="plugdev", TAG+="uaccess"
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="0d28", MODE="0666", GROUP="plugdev", TAG+="uaccess"
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="c251", MODE="0666", GROUP="plugdev", TAG+="uaccess"
