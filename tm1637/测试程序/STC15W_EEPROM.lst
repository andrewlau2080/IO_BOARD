  23          void IapProgramByte(uint addr, uchar dat)
  24          {
  25   1          IAP_CONTR = ENABLE_IAP;         //使能IAP
  26   1          IAP_CMD = CMD_PROGRAM;          //设置IAP命令
  27   1          IAP_ADDRL = addr;               //设置IAP低地址
  28   1          IAP_ADDRH = addr >> 8;          //设置IAP高地址
  29   1          IAP_DATA = dat;                 //写ISP/IAP/EEPROM数据
  30   1          IAP_TRIG = 0x5a;                //写触发命令(0x5a)
  31   1          IAP_TRIG = 0xa5;                //写触发命令(0xa5)
  32   1          _nop_();  
  33   1              _nop_();                      //等待ISP/IAP/EEPROM操作完成
  34   1          IapIdle();
  35   1      }
  36          
  37          uchar IapReadByte(uint addr)
  38          {
  39   1          uchar dat;                       //数据缓冲区
  40   1      
  41   1          IAP_CONTR = ENABLE_IAP;         //使能IAP
  42   1          IAP_CMD = CMD_READ;             //设置IAP命令
  43   1          IAP_ADDRL = addr;               //设置IAP低地址
  44   1          IAP_ADDRH = addr >> 8;          //设置IAP高地址
  45   1          IAP_TRIG = 0x5a;                //写触发命令(0x5a)
  46   1          IAP_TRIG = 0xa5;                //写触发命令(0xa5)
  47   1          _nop_();                        //等待ISP/IAP/EEPROM操作完成
  48   1              _nop_();
  49   1          dat = IAP_DATA;                 //读ISP/IAP/EEPROM数据
  50   1          IapIdle();                      //关闭IAP功能
  51   1      
  52   1          return dat;                     //返回
  53   1      }
